{"id":827,"slug":"take-shelter","url":"https://www.brightonfringe.org/events/take-shelter/","title":"Take Shelter","company":"Take Shelter - WW2 Air Raid Shelter","genre":"Tours","description":"Step back in time to explore a unique part of Brighton's wartime history with one of our air raid shelter tours. During the war, every school would have had its own air raid shelter, now one of the only surviving examples in the UK is under the playground at Downs Junior School. There is lots to do and see during your visit to Take Shelter: Tour the shelter with one of our knowledgeable guides (ticketed), play one of our vintage fair games, browse our World War II museum, chat with our veterans about their wartime experiences, soak up the vintage sounds and learn wartime dances on our dancefloor, or enjoy a cup of tea and bite to eat from Mrs Button's Tea Room and take home a souvenir from the Take Shelter shop.","duration_minutes":45,"age_suitability":"0+","image_url":"https://content.brightonfringe.org/wp-content/uploads/2025/12/11-30-2025-153719-3975.jpg","website":"","instagram":"https://www.instagram.com/brightonfringe/","twitter":"https://twitter.com/brightonfringe","facebook":"https://www.facebook.com/brightonfringefestival","accessibility_features":["Accessible"],"content_warnings":["Loud"],"cast":[],"scraped_at":"2026-05-19T15:11:18.538014","venue":{"id":113,"slug":"downs-junior-school","name":"Downs Junior School","address":null,"url":"https://www.brightonfringe.org/venues/downs-junior-school","lat":50.8394195,"lng":-0.1343813},"performances":[{"id":33858,"date":"2026-05-31","time":"","standard_price":null,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":33859,"date":"2026-05-16","time":"10:00","standard_price":10.0,"concession_price":8.0,"is_sold_out":false,"booking_url":""},{"id":33860,"date":"2026-05-16","time":"10:15","standard_price":10.0,"concession_price":8.0,"is_sold_out":false,"booking_url":""},{"id":33861,"date":"2026-05-16","time":"10:3