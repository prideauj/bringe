{"id":840,"slug":"witchcraft-magic-tour","url":"https://www.brightonfringe.org/events/witchcraft-magic-tour/","title":"Witchcraft Magic Tour","company":"Strange Strolls","genre":"Tours","description":"Returning after a sold-out run at last year's Fringe, come with us to find out about the mystical and esoteric history of Brighton. The tour will take you from a ley line nexus to the first blue plaque to ever honour a witch, covering stone circles, an alleged occult cult and the satanic panic along the way. Find out about the witchcraft trials in Sussex, Aleister Crowley's link to Brighton and life for witches in Regency England. If you have any questions or accessibility requirements please email me at [email protected]","duration_minutes":90,"age_suitability":"16+","image_url":"https://content.brightonfringe.org/wp-content/uploads/2025/12/12-03-2025-084809-6517.jpg","website":"","instagram":"https://www.instagram.com/brightonfringe/","twitter":"https://twitter.com/brightonfringe","facebook":"https://www.facebook.com/brightonfringefestival","accessibility_features":[],"content_warnings":[],"cast":[],"scraped_at":"2026-05-19T09:32:51.274609","venue":{"id":117,"slug":"meet-outside-the-walrus","name":"MEET: Outside The Walrus","address":null,"url":"https://www.brightonfringe.org/venues/meet-outside-the-walrus","lat":50.8210133,"lng":-0.1421607},"performances":[{"id":27108,"date":"2026-05-31","time":"","standard_price":null,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":27109,"date":"2026-05-15","time":"18:00","standard_price":10.0,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":27110,"date":"2026-05-17","time":"14:00","standard_price":10.0,"concession_price":null,"is_sold_out":true,"booking_url":""},{"id":27111,"date":"2026-05-17","time":"16:00","standard_price":10.0,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":27112,"date":"2026-05-21","time":"18:00","standard_price":10.0,"concession_price":null,"is_sold_o