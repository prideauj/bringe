{"id":385,"slug":"shadow-light-songs-my-brother-taught-me-exhibition","url":"https://www.brightonfringe.org/events/shadow-light-songs-my-brother-taught-me-exhibition/","title":"Shadow Light Songs My Brother Taught Me Exhibition","company":"Shiny Pin Productions Ltd","genre":"Exhibitions","description":"My first exhibition of new work, since I took part in the 2nd Art & Science Symposium & Exhibition at the Tsinghua Academy of Arts in Beijing in 2006. The seeds for this show were sown that same year when a treasured acoustic guitar of mine got broken and instead of ditching it (a luthier informed me it was beyond repair) I began photographing it. 20 years on, I've created 20 works – prints, collage, assemblage – that are inspired by and a tribute to my late brother Stephen who tragically took his own life at age 20. Fifty years on, I’m still shining a light into those shadows.","duration_minutes":300,"age_suitability":"0+","image_url":"https://content.brightonfringe.org/wp-content/uploads/2026/03/01-21-2026-122816-8900.jpg","website":"","instagram":"https://www.instagram.com/brightonfringe/","twitter":"https://twitter.com/brightonfringe","facebook":"https://www.facebook.com/brightonfringefestival","accessibility_features":["Wheelchair","Accessible","Assistance Dog"],"content_warnings":["Assemblage includes fire damaged items"],"cast":[],"scraped_at":"2026-05-19T09:31:54.718546","venue":{"id":47,"slug":"phoenix-art-space","name":"Phoenix Art Space","address":null,"url":"https://www.brightonfringe.org/venues/phoenix-art-space","lat":50.8287779,"lng":-0.1338337},"performances":[{"id":25277,"date":"2026-05-31","time":"","standard_price":null,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":25278,"date":"2026-05-01","time":"12:00","standard_price":0.0,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":25279,"date":"2026-05-02","time":"12:00","standard_price":0.0,"concession_price":null,"is_sold_out":false,"booking_url":""},{"id":25280,"